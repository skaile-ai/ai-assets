{
  "description": "Writes typed scalars (string, integer, float, boolean, date) into named single cells on sheet 'Object'. Ported from xlport 1object; B9 uses Excel's serial-date 43466 (= 2019-01-01) since the template already has the date format applied at s=4.",
  "operations": [
    { "tool": "range.set", "arguments": { "sheet": "Object", "start": "B3", "values": [["pid1"]] } },
    { "tool": "range.set", "arguments": { "sheet": "Object", "start": "B4", "values": [["Project Name"]] } },
    { "tool": "range.set", "arguments": { "sheet": "Object", "start": "B5", "values": [[114325352]] } },
    { "tool": "range.set", "arguments": { "sheet": "Object", "start": "B6", "values": [[-143242.25]] } },
    { "tool": "range.set", "arguments": { "sheet": "Object", "start": "B7", "values": [[true]] } },
    { "tool": "range.set", "arguments": { "sheet": "Object", "start": "B9", "values": [[43466]] } }
  ]
}
