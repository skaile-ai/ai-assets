{
  "$schema": "./flow.schema.json",
  "id": "cli-app",
  "version": "1.0",
  "name": "CLI Application",
  "description": "Command-line tool pipeline — no UI, no screens, no brand, no mockups. Features describe commands, flags, and output formats.",
  "meta": {
    "icon": "i-heroicons-command-line",
    "category": "cli",
    "tags": ["cli", "tool", "no-ui", "terminal"],
    "onboarding": {
      "input_style": "freeform",
      "placeholder": "e.g. A CLI tool that converts CSV files to JSON with column filtering and schema validation..."
    }
  },
  "globals": {
    "research_depth": "light",
    "approval_mode": "checkpoint",
    "auto_review": false,
    "subagent_mode": true,
    "verbosity": "standard",
    "cli_mode": true
  },
  "modes": {
    "research": {
      "enabled": true,
      "skill": "concept/discovery/research",
      "triggers": ["overview", "features"],
      "parameters": {
        "topics": ["domain", "competitors", "patterns"]
      }
    },
    "standards": {
      "enabled": false
    }
  },
  "nodes": [
    {
      "id": "g-concept",
      "type": "group",
      "position": { "x": 0, "y": 0 },
      "style": { "width": 920, "height": 360, "backgroundColor": "rgba(99,102,241,0.04)", "border": "1px solid rgba(99,102,241,0.2)", "borderRadius": "12px" },
      "data": { "label": "Concept", "phase": "conceptualization" }
    },
    {
      "id": "g-implement",
      "type": "group",
      "position": { "x": 0, "y": 400 },
      "style": { "width": 1160, "height": 320, "backgroundColor": "rgba(16,185,129,0.04)", "border": "1px solid rgba(16,185,129,0.2)", "borderRadius": "12px" },
      "data": { "label": "Implementation", "phase": "implementation" }
    },

    { "id": "overview",        "type": "skill", "parentNode": "g-concept",   "position": { "x": 40,  "y": 140 }, "data": { "skill": "concept/discovery/overview",    "label": "Project Brief",     "optional": false, "parameters": { "input_style": "freeform", "note": "Describe CLI commands, flags, and expected output" } } },
    { "id": "features",        "type": "skill", "parentNode": "g-concept",   "position": { "x": 280, "y": 140 }, "data": { "skill": "concept/experience/features",   "label": "Features",          "optional": false, "parameters": { "cli_mode": true, "describe_as_commands": true } } },
    { "id": "techstack",       "type": "skill", "parentNode": "g-concept",   "position": { "x": 280, "y": 260 }, "data": { "skill": "concept/blueprint/techstack",   "label": "Tech Stack",        "optional": false, "parallel_group": "identity" } },
    { "id": "architecture",    "type": "skill", "parentNode": "g-concept",   "position": { "x": 560, "y": 60  }, "data": { "skill": "concept/blueprint/architecture","label": "Architecture",      "optional": true  } },
    { "id": "datamodel",       "type": "skill", "parentNode": "g-concept",   "position": { "x": 560, "y": 200 }, "data": { "skill": "concept/blueprint/datamodel",   "label": "Data Model",        "optional": false, "parameters": { "note": "Config files, storage schemas, output formats" } } },
    { "id": "journeys",        "type": "skill", "parentNode": "g-concept",   "position": { "x": 280, "y": 60  }, "data": { "skill": "concept/experience/journeys",   "label": "User Journeys",     "optional": true,  "parameters": { "min_stages": ["hero"], "note": "Map command-line workflows as journeys" } } },

    { "id": "scaffold",        "type": "skill", "parentNode": "g-implement", "position": { "x": 40,  "y": 140 }, "data": { "skill": "implement/scaffold",             "label": "Scaffold",          "optional": false, "parameters": { "project_type": "cli", "package_manager": "bun" } } },
    { "id": "foundation",      "type": "skill", "parentNode": "g-implement", "position": { "x": 280, "y": 140 }, "data": { "skill": "implement/foundation",           "label": "Foundation",        "optional": true,  "parameters": { "skip_ui_shell": true } } },
    { "id": "migrate",         "type": "skill", "parentNode": "g-implement", "position": { "x": 520, "y": 60  }, "data": { "skill": "implement/migrate",              "label": "Migrate",           "optional": true  } },
    { "id": "seed",            "type": "skill", "parentNode": "g-implement", "position": { "x": 520, "y": 220 }, "data": { "skill": "implement/seed",                 "label": "Seed",              "optional": true  } },
    { "id": "feature",         "type": "skill", "parentNode": "g-implement", "position": { "x": 760, "y": 140 }, "data": { "skill": "implement/feature",              "label": "Feature",           "optional": false, "subagent": true, "parameters": { "tdd": true } } },
    { "id": "test-unit",       "type": "skill", "parentNode": "g-implement", "position": { "x": 920, "y": 60  }, "data": { "skill": "support/test-unit",              "label": "Unit Tests",        "optional": false, "subagent": true } },
    { "id": "test-integration","type": "skill", "parentNode": "g-implement", "position": { "x": 920, "y": 200 }, "data": { "skill": "support/test-integration",       "label": "Integration Tests", "optional": false, "subagent": true } },
    { "id": "verify",          "type": "skill", "parentNode": "g-implement", "position": { "x": 1100,"y": 140 }, "data": { "skill": "implement/verify",               "label": "Verify",            "optional": false, "subagent": true } }
  ],
  "edges": [
    { "id": "e-overview-journeys",     "source": "overview",  "target": "journeys",        "type": "optional" },
    { "id": "e-overview-features",     "source": "overview",  "target": "features",        "type": "flow"     },
    { "id": "e-overview-techstack",    "source": "overview",  "target": "techstack",       "type": "parallel" },
    { "id": "e-journeys-features",     "source": "journeys",  "target": "features",        "type": "optional" },
    { "id": "e-features-architecture", "source": "features",  "target": "architecture",    "type": "optional" },
    { "id": "e-techstack-architecture","source": "techstack", "target": "architecture",    "type": "optional" },
    { "id": "e-features-datamodel",    "source": "features",  "target": "datamodel",       "type": "flow"     },
    { "id": "e-techstack-datamodel",   "source": "techstack", "target": "datamodel",       "type": "flow"     },
    { "id": "e-architecture-datamodel","source": "architecture","target": "datamodel",     "type": "optional" },
    { "id": "e-datamodel-scaffold",    "source": "datamodel", "target": "scaffold",        "type": "flow"     },
    { "id": "e-scaffold-foundation",   "source": "scaffold",  "target": "foundation",      "type": "optional" },
    { "id": "e-scaffold-migrate",      "source": "scaffold",  "target": "migrate",         "type": "optional" },
    { "id": "e-migrate-seed",          "source": "migrate",   "target": "seed",            "type": "optional" },
    { "id": "e-scaffold-feature",      "source": "scaffold",  "target": "feature",         "type": "flow"     },
    { "id": "e-foundation-feature",    "source": "foundation","target": "feature",         "type": "optional" },
    { "id": "e-feature-unit",          "source": "feature",   "target": "test-unit",       "type": "flow"     },
    { "id": "e-feature-integration",   "source": "feature",   "target": "test-integration","type": "flow"     },
    { "id": "e-unit-verify",           "source": "test-unit", "target": "verify",          "type": "flow"     },
    { "id": "e-integration-verify",    "source": "test-integration","target": "verify",    "type": "flow"     }
  ],
  "entry": "overview"
}
