{
  "$schema": "./flow.schema.json",
  "id": "mvp",
  "version": "1.0",
  "name": "Minimum Viable Product",
  "description": "Full concept-to-working-app pipeline. Journeys + features + brand + data model + screens, then scaffold, implement, test, verify.",
  "meta": {
    "icon": "i-heroicons-rocket-launch",
    "category": "full-stack",
    "tags": ["mvp", "web-app", "full-pipeline"],
    "onboarding": {
      "input_style": "structured",
      "fields": ["app_name", "problem", "audience", "notes"]
    }
  },
  "globals": {
    "research_depth": "moderate",
    "approval_mode": "checkpoint",
    "auto_review": false,
    "subagent_mode": true,
    "verbosity": "standard"
  },
  "modes": {
    "research": {
      "enabled": true,
      "skill": "concept/discovery/research",
      "triggers": ["overview", "features", "brand-visual", "datamodel", "screens"],
      "parameters": {
        "topics": ["domain", "competitors", "audiences", "design_inspiration", "patterns"]
      }
    },
    "standards": {
      "enabled": false,
      "skill": "standards/discover",
      "inject_skill": "standards/inject",
      "trigger_after": "overview"
    }
  },
  "nodes": [
    {
      "id": "g-concept",
      "type": "group",
      "position": { "x": 0, "y": 0 },
      "style": { "width": 1680, "height": 520, "backgroundColor": "rgba(99,102,241,0.04)", "border": "1px solid rgba(99,102,241,0.2)", "borderRadius": "12px" },
      "data": { "label": "Concept", "phase": "conceptualization" }
    },
    {
      "id": "g-implement",
      "type": "group",
      "position": { "x": 0, "y": 560 },
      "style": { "width": 1680, "height": 360, "backgroundColor": "rgba(16,185,129,0.04)", "border": "1px solid rgba(16,185,129,0.2)", "borderRadius": "12px" },
      "data": { "label": "Implementation", "phase": "implementation" }
    },

    { "id": "overview",       "type": "skill", "parentNode": "g-concept",    "position": { "x": 40,   "y": 200 }, "data": { "skill": "concept/discovery/overview",       "label": "Project Brief",      "optional": false, "parameters": { "input_style": "structured", "fields": ["app_name", "problem", "audience", "notes"] } } },
    { "id": "journeys",       "type": "skill", "parentNode": "g-concept",    "position": { "x": 280,  "y": 80  }, "data": { "skill": "concept/experience/journeys",      "label": "User Journeys",      "optional": true,  "parameters": { "hero_approval_required": true, "min_stages": ["hero", "vital"] } } },
    { "id": "brand-visual",   "type": "skill", "parentNode": "g-concept",    "position": { "x": 280,  "y": 200 }, "data": { "skill": "concept/discovery/brand-visual",   "label": "Brand Visual",       "optional": false, "parallel_group": "identity" } },
    { "id": "techstack",      "type": "skill", "parentNode": "g-concept",    "position": { "x": 280,  "y": 320 }, "data": { "skill": "concept/blueprint/techstack",      "label": "Tech Stack",         "optional": false, "parallel_group": "identity" } },
    { "id": "features",       "type": "skill", "parentNode": "g-concept",    "position": { "x": 560,  "y": 200 }, "data": { "skill": "concept/experience/features",      "label": "Features",           "optional": false, "subagent": true } },
    { "id": "brand-behavioral","type": "skill", "parentNode": "g-concept",   "position": { "x": 560,  "y": 80  }, "data": { "skill": "concept/discovery/brand-behavioral","label": "Brand Behavioral",   "optional": true } },
    { "id": "architecture",   "type": "skill", "parentNode": "g-concept",    "position": { "x": 840,  "y": 80  }, "data": { "skill": "concept/blueprint/architecture",   "label": "Architecture",       "optional": true,  "subagent": true } },
    { "id": "datamodel",      "type": "skill", "parentNode": "g-concept",    "position": { "x": 840,  "y": 200 }, "data": { "skill": "concept/blueprint/datamodel",      "label": "Data Model",         "optional": false, "subagent": true } },
    { "id": "screens",        "type": "skill", "parentNode": "g-concept",    "position": { "x": 1120, "y": 200 }, "data": { "skill": "concept/experience/screens",       "label": "Screens",            "optional": false, "subagent": true } },
    { "id": "components",     "type": "skill", "parentNode": "g-concept",    "position": { "x": 1120, "y": 80  }, "data": { "skill": "concept/experience/components",    "label": "Components",         "optional": true  } },
    { "id": "mock",           "type": "skill", "parentNode": "g-concept",    "position": { "x": 1400, "y": 80  }, "data": { "skill": "concept/experience/mock",           "label": "Mockups",            "optional": true,  "parameters": { "include_seed_data": true } } },
    { "id": "storybook",      "type": "skill", "parentNode": "g-concept",    "position": { "x": 1400, "y": 240 }, "data": { "skill": "concept/experience/storybook",      "label": "Storybook",          "optional": true  } },

    { "id": "scaffold",       "type": "skill", "parentNode": "g-implement",  "position": { "x": 40,   "y": 140 }, "data": { "skill": "implement/scaffold",                "label": "Scaffold",           "optional": false, "parameters": { "package_manager": "bun" } } },
    { "id": "foundation",     "type": "skill", "parentNode": "g-implement",  "position": { "x": 280,  "y": 140 }, "data": { "skill": "implement/foundation",              "label": "Foundation",         "optional": true  } },
    { "id": "design",         "type": "skill", "parentNode": "g-implement",  "position": { "x": 280,  "y": 260 }, "data": { "skill": "implement/design",                  "label": "Design",             "optional": true  } },
    { "id": "migrate",        "type": "skill", "parentNode": "g-implement",  "position": { "x": 560,  "y": 60  }, "data": { "skill": "implement/migrate",                 "label": "Migrate",            "optional": true  } },
    { "id": "seed",           "type": "skill", "parentNode": "g-implement",  "position": { "x": 560,  "y": 220 }, "data": { "skill": "implement/seed",                    "label": "Seed",               "optional": true  } },
    { "id": "feature",        "type": "skill", "parentNode": "g-implement",  "position": { "x": 800,  "y": 140 }, "data": { "skill": "implement/feature",                 "label": "Feature",            "optional": false, "subagent": true, "parameters": { "tdd": true } } },
    { "id": "test-integration","type": "skill", "parentNode": "g-implement", "position": { "x": 1040, "y": 60  }, "data": { "skill": "support/test-integration",          "label": "Integration Tests",  "optional": true,  "subagent": true } },
    { "id": "e2e",            "type": "skill", "parentNode": "g-implement",  "position": { "x": 1040, "y": 220 }, "data": { "skill": "support/e2e",                       "label": "E2E Tests",          "optional": false, "subagent": true } },
    { "id": "verify",         "type": "skill", "parentNode": "g-implement",  "position": { "x": 1280, "y": 140 }, "data": { "skill": "implement/verify",                  "label": "Verify",             "optional": false, "subagent": true } }
  ],
  "edges": [
    { "id": "e-overview-journeys",        "source": "overview",       "target": "journeys",        "type": "optional" },
    { "id": "e-overview-brand",           "source": "overview",       "target": "brand-visual",    "type": "parallel" },
    { "id": "e-overview-techstack",       "source": "overview",       "target": "techstack",       "type": "parallel" },
    { "id": "e-journeys-features",        "source": "journeys",       "target": "features",        "type": "optional" },
    { "id": "e-overview-features",        "source": "overview",       "target": "features",        "type": "flow"     },
    { "id": "e-brand-behavioral",         "source": "brand-visual",   "target": "brand-behavioral","type": "optional" },
    { "id": "e-features-architecture",    "source": "features",       "target": "architecture",    "type": "optional" },
    { "id": "e-techstack-architecture",   "source": "techstack",      "target": "architecture",    "type": "optional" },
    { "id": "e-features-datamodel",       "source": "features",       "target": "datamodel",       "type": "flow"     },
    { "id": "e-techstack-datamodel",      "source": "techstack",      "target": "datamodel",       "type": "flow"     },
    { "id": "e-architecture-datamodel",   "source": "architecture",   "target": "datamodel",       "type": "optional" },
    { "id": "e-datamodel-screens",        "source": "datamodel",      "target": "screens",         "type": "flow"     },
    { "id": "e-brand-screens",            "source": "brand-visual",   "target": "screens",         "type": "flow"     },
    { "id": "e-techstack-screens",        "source": "techstack",      "target": "screens",         "type": "flow"     },
    { "id": "e-screens-components",       "source": "screens",        "target": "components",      "type": "optional" },
    { "id": "e-screens-mock",             "source": "screens",        "target": "mock",            "type": "optional" },
    { "id": "e-screens-storybook",        "source": "screens",        "target": "storybook",       "type": "optional" },
    { "id": "e-techstack-storybook",      "source": "techstack",      "target": "storybook",       "type": "optional" },
    { "id": "e-brand-storybook",          "source": "brand-visual",   "target": "storybook",       "type": "optional" },
    { "id": "e-screens-scaffold",         "source": "screens",        "target": "scaffold",        "type": "flow"     },
    { "id": "e-scaffold-foundation",      "source": "scaffold",       "target": "foundation",      "type": "optional" },
    { "id": "e-foundation-design",        "source": "foundation",     "target": "design",          "type": "optional" },
    { "id": "e-scaffold-design",          "source": "scaffold",       "target": "design",          "type": "optional" },
    { "id": "e-scaffold-migrate",         "source": "scaffold",       "target": "migrate",         "type": "optional" },
    { "id": "e-migrate-seed",             "source": "migrate",        "target": "seed",            "type": "optional" },
    { "id": "e-scaffold-seed",            "source": "scaffold",       "target": "seed",            "type": "optional" },
    { "id": "e-scaffold-feature",         "source": "scaffold",       "target": "feature",         "type": "flow"     },
    { "id": "e-design-feature",           "source": "design",         "target": "feature",         "type": "optional" },
    { "id": "e-feature-integration",      "source": "feature",        "target": "test-integration","type": "optional" },
    { "id": "e-feature-e2e",              "source": "feature",        "target": "e2e",             "type": "flow"     },
    { "id": "e-integration-verify",       "source": "test-integration","target": "verify",         "type": "optional" },
    { "id": "e-e2e-verify",               "source": "e2e",            "target": "verify",          "type": "flow"     }
  ],
  "entry": "overview"
}
