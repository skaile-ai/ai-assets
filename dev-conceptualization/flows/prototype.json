{
  "$schema": "./flow.schema.json",
  "id": "prototype",
  "version": "1.0",
  "name": "Quick Prototype",
  "description": "Concept + interactive mockups only. No data model, no implementation. Fastest path to a clickable prototype for user validation.",
  "meta": {
    "icon": "i-heroicons-cursor-arrow-ripple",
    "category": "prototype",
    "tags": ["prototype", "validation", "no-code", "fast"],
    "onboarding": {
      "input_style": "freeform",
      "placeholder": "e.g. Restaurant reservation & waitlist manager for small venues..."
    }
  },
  "globals": {
    "research_depth": "light",
    "approval_mode": "checkpoint",
    "auto_review": false,
    "subagent_mode": false,
    "verbosity": "brief"
  },
  "modes": {
    "research": {
      "enabled": true,
      "skill": "concept/discovery/research",
      "triggers": ["overview", "brand-visual"],
      "parameters": {
        "topics": ["competitors", "design_inspiration", "colors_fonts"]
      }
    },
    "standards": {
      "enabled": false
    }
  },
  "nodes": [
    {
      "id": "g-concept",
      "type": "group",
      "position": { "x": 0, "y": 0 },
      "style": { "width": 1400, "height": 400, "backgroundColor": "rgba(99,102,241,0.04)", "border": "1px solid rgba(99,102,241,0.2)", "borderRadius": "12px" },
      "data": { "label": "Concept", "phase": "conceptualization" }
    },

    { "id": "overview",     "type": "skill", "parentNode": "g-concept", "position": { "x": 40,  "y": 160 }, "data": { "skill": "concept/discovery/overview",     "label": "Project Brief",    "optional": false, "parameters": { "input_style": "freeform" } } },
    { "id": "journeys",     "type": "skill", "parentNode": "g-concept", "position": { "x": 280, "y": 60  }, "data": { "skill": "concept/experience/journeys",    "label": "User Journeys",    "optional": true,  "parameters": { "hero_approval_required": true, "min_stages": ["hero"] } } },
    { "id": "brand-visual", "type": "skill", "parentNode": "g-concept", "position": { "x": 280, "y": 200 }, "data": { "skill": "concept/discovery/brand-visual", "label": "Brand Visual",     "optional": false, "parallel_group": "identity" } },
    { "id": "techstack",    "type": "skill", "parentNode": "g-concept", "position": { "x": 280, "y": 320 }, "data": { "skill": "concept/blueprint/techstack",    "label": "Tech Stack",       "optional": false, "parallel_group": "identity" } },
    { "id": "features",     "type": "skill", "parentNode": "g-concept", "position": { "x": 560, "y": 200 }, "data": { "skill": "concept/experience/features",    "label": "Features",         "optional": false } },
    { "id": "screens",      "type": "skill", "parentNode": "g-concept", "position": { "x": 840, "y": 200 }, "data": { "skill": "concept/experience/screens",     "label": "Screens",          "optional": false } },
    { "id": "mock",         "type": "skill", "parentNode": "g-concept", "position": { "x": 1120,"y": 200 }, "data": { "skill": "concept/experience/mock",        "label": "Mockups",          "optional": false, "parameters": { "framework": "alpine", "include_seed_data": true, "include_interactions": true } } },
    { "id": "storybook",    "type": "skill", "parentNode": "g-concept", "position": { "x": 1120,"y": 80  }, "data": { "skill": "concept/experience/storybook",   "label": "Storybook",        "optional": true  } }
  ],
  "edges": [
    { "id": "e-overview-journeys",     "source": "overview",     "target": "journeys",    "type": "optional" },
    { "id": "e-overview-brand",        "source": "overview",     "target": "brand-visual","type": "parallel" },
    { "id": "e-overview-techstack",    "source": "overview",     "target": "techstack",   "type": "parallel" },
    { "id": "e-journeys-features",     "source": "journeys",     "target": "features",    "type": "optional" },
    { "id": "e-overview-features",     "source": "overview",     "target": "features",    "type": "flow"     },
    { "id": "e-features-screens",      "source": "features",     "target": "screens",     "type": "flow"     },
    { "id": "e-brand-screens",         "source": "brand-visual", "target": "screens",     "type": "flow"     },
    { "id": "e-techstack-screens",     "source": "techstack",    "target": "screens",     "type": "flow"     },
    { "id": "e-screens-mock",          "source": "screens",      "target": "mock",        "type": "flow"     },
    { "id": "e-screens-storybook",     "source": "screens",      "target": "storybook",   "type": "optional" },
    { "id": "e-techstack-storybook",   "source": "techstack",    "target": "storybook",   "type": "optional" },
    { "id": "e-brand-storybook",       "source": "brand-visual", "target": "storybook",   "type": "optional" }
  ],
  "entry": "overview"
}
