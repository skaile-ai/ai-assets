{
  "$schema": "./flow.schema.json",
  "id": "product",
  "version": "1.0",
  "name": "Production App",
  "description": "Complete pipeline — all optional steps included. Deep research, behavioral brand, full architecture, comprehensive testing, readiness gate before implementation.",
  "meta": {
    "icon": "i-heroicons-building-office-2",
    "category": "full-stack",
    "tags": ["production", "enterprise", "full-pipeline", "all-steps"],
    "onboarding": {
      "input_style": "structured",
      "fields": ["app_name", "problem", "audience", "notes", "constraints"]
    }
  },
  "globals": {
    "research_depth": "deep",
    "approval_mode": "checkpoint",
    "auto_review": true,
    "subagent_mode": true,
    "verbosity": "detailed"
  },
  "modes": {
    "research": {
      "enabled": true,
      "skill": "concept/discovery/research",
      "triggers": ["overview", "features", "brand-visual", "datamodel", "screens"],
      "parameters": {
        "topics": ["domain", "competitors", "audiences", "design_inspiration", "patterns", "colors_fonts", "behavioral_patterns"]
      }
    },
    "standards": {
      "enabled": true,
      "skill": "standards/discover",
      "inject_skill": "standards/inject",
      "trigger_after": "overview"
    }
  },
  "nodes": [
    {
      "id": "g-concept",
      "type": "group",
      "position": { "x": 0, "y": 0 },
      "style": { "width": 1960, "height": 540, "backgroundColor": "rgba(99,102,241,0.04)", "border": "1px solid rgba(99,102,241,0.2)", "borderRadius": "12px" },
      "data": { "label": "Concept", "phase": "conceptualization" }
    },
    {
      "id": "g-implement",
      "type": "group",
      "position": { "x": 0, "y": 580 },
      "style": { "width": 1960, "height": 460, "backgroundColor": "rgba(16,185,129,0.04)", "border": "1px solid rgba(16,185,129,0.2)", "borderRadius": "12px" },
      "data": { "label": "Implementation", "phase": "implementation" }
    },

    { "id": "overview",        "type": "skill", "parentNode": "g-concept",   "position": { "x": 40,   "y": 240 }, "data": { "skill": "concept/discovery/overview",        "label": "Project Brief",     "optional": false, "parameters": { "input_style": "structured" } } },
    { "id": "journeys",        "type": "skill", "parentNode": "g-concept",   "position": { "x": 280,  "y": 80  }, "data": { "skill": "concept/experience/journeys",       "label": "User Journeys",     "optional": false, "parameters": { "hero_approval_required": true } } },
    { "id": "brand-visual",    "type": "skill", "parentNode": "g-concept",   "position": { "x": 280,  "y": 240 }, "data": { "skill": "concept/discovery/brand-visual",    "label": "Brand Visual",      "optional": false, "parallel_group": "identity" } },
    { "id": "techstack",       "type": "skill", "parentNode": "g-concept",   "position": { "x": 280,  "y": 400 }, "data": { "skill": "concept/blueprint/techstack",       "label": "Tech Stack",        "optional": false, "parallel_group": "identity" } },
    { "id": "features",        "type": "skill", "parentNode": "g-concept",   "position": { "x": 560,  "y": 240 }, "data": { "skill": "concept/experience/features",       "label": "Features",          "optional": false, "subagent": true } },
    { "id": "behaviors",       "type": "skill", "parentNode": "g-concept",   "position": { "x": 560,  "y": 80  }, "data": { "skill": "concept/experience/behaviors",      "label": "Behaviors",         "optional": false } },
    { "id": "brand-behavioral","type": "skill", "parentNode": "g-concept",   "position": { "x": 560,  "y": 400 }, "data": { "skill": "concept/discovery/brand-behavioral","label": "Brand Behavioral",  "optional": false } },
    { "id": "architecture",    "type": "skill", "parentNode": "g-concept",   "position": { "x": 840,  "y": 80  }, "data": { "skill": "concept/blueprint/architecture",    "label": "Architecture",      "optional": false, "subagent": true } },
    { "id": "datamodel",       "type": "skill", "parentNode": "g-concept",   "position": { "x": 840,  "y": 240 }, "data": { "skill": "concept/blueprint/datamodel",       "label": "Data Model",        "optional": false, "subagent": true } },
    { "id": "screens",         "type": "skill", "parentNode": "g-concept",   "position": { "x": 1120, "y": 240 }, "data": { "skill": "concept/experience/screens",        "label": "Screens",           "optional": false, "subagent": true } },
    { "id": "components",      "type": "skill", "parentNode": "g-concept",   "position": { "x": 1120, "y": 80  }, "data": { "skill": "concept/experience/components",     "label": "Components",        "optional": false } },
    { "id": "mock",            "type": "skill", "parentNode": "g-concept",   "position": { "x": 1560, "y": 80  }, "data": { "skill": "concept/experience/mock",           "label": "Mockups",           "optional": true,  "parameters": { "framework": "vue", "include_seed_data": true } } },
    { "id": "storybook",       "type": "skill", "parentNode": "g-concept",   "position": { "x": 1560, "y": 240 }, "data": { "skill": "concept/experience/storybook",      "label": "Storybook",         "optional": false } },

    { "id": "ready",           "type": "skill", "parentNode": "g-implement", "position": { "x": 40,   "y": 180 }, "data": { "skill": "support/ready",                     "label": "Readiness Gate",    "optional": false } },
    { "id": "scaffold",        "type": "skill", "parentNode": "g-implement", "position": { "x": 280,  "y": 180 }, "data": { "skill": "implement/scaffold",                 "label": "Scaffold",          "optional": false, "parameters": { "package_manager": "bun" } } },
    { "id": "foundation",      "type": "skill", "parentNode": "g-implement", "position": { "x": 520,  "y": 180 }, "data": { "skill": "implement/foundation",               "label": "Foundation",        "optional": false } },
    { "id": "design",          "type": "skill", "parentNode": "g-implement", "position": { "x": 520,  "y": 320 }, "data": { "skill": "implement/design",                   "label": "Design",            "optional": true  } },
    { "id": "migrate",         "type": "skill", "parentNode": "g-implement", "position": { "x": 760,  "y": 80  }, "data": { "skill": "implement/migrate",                  "label": "Migrate",           "optional": false } },
    { "id": "seed",            "type": "skill", "parentNode": "g-implement", "position": { "x": 760,  "y": 280 }, "data": { "skill": "implement/seed",                     "label": "Seed",              "optional": false } },
    { "id": "feature",         "type": "skill", "parentNode": "g-implement", "position": { "x": 1000, "y": 180 }, "data": { "skill": "implement/feature",                  "label": "Feature",           "optional": false, "subagent": true, "parameters": { "tdd": true, "coverage_threshold": 80 } } },
    { "id": "test-plan",       "type": "skill", "parentNode": "g-implement", "position": { "x": 1000, "y": 60  }, "data": { "skill": "support/test-plan",                  "label": "Test Plan",         "optional": false } },
    { "id": "test-unit",       "type": "skill", "parentNode": "g-implement", "position": { "x": 1240, "y": 60  }, "data": { "skill": "support/test-unit",                  "label": "Unit Tests",        "optional": false, "subagent": true } },
    { "id": "test-integration","type": "skill", "parentNode": "g-implement", "position": { "x": 1240, "y": 200 }, "data": { "skill": "support/test-integration",           "label": "Integration Tests", "optional": false, "subagent": true } },
    { "id": "e2e",             "type": "skill", "parentNode": "g-implement", "position": { "x": 1240, "y": 340 }, "data": { "skill": "support/e2e",                        "label": "E2E Tests",         "optional": false, "subagent": true } },
    { "id": "verify",          "type": "skill", "parentNode": "g-implement", "position": { "x": 1480, "y": 200 }, "data": { "skill": "implement/verify",                   "label": "Verify",            "optional": false, "subagent": true } }
  ],
  "edges": [
    { "id": "e-overview-journeys",     "source": "overview",       "target": "journeys",        "type": "flow"     },
    { "id": "e-overview-brand",        "source": "overview",       "target": "brand-visual",    "type": "parallel" },
    { "id": "e-overview-techstack",    "source": "overview",       "target": "techstack",       "type": "parallel" },
    { "id": "e-journeys-features",     "source": "journeys",       "target": "features",        "type": "flow"     },
    { "id": "e-journeys-behaviors",    "source": "journeys",       "target": "behaviors",       "type": "flow"     },
    { "id": "e-brand-behavioral",      "source": "brand-visual",   "target": "brand-behavioral","type": "flow"     },
    { "id": "e-features-architecture", "source": "features",       "target": "architecture",    "type": "flow"     },
    { "id": "e-techstack-architecture","source": "techstack",      "target": "architecture",    "type": "flow"     },
    { "id": "e-features-datamodel",    "source": "features",       "target": "datamodel",       "type": "flow"     },
    { "id": "e-techstack-datamodel",   "source": "techstack",      "target": "datamodel",       "type": "flow"     },
    { "id": "e-architecture-datamodel","source": "architecture",   "target": "datamodel",       "type": "flow"     },
    { "id": "e-behaviors-datamodel",   "source": "behaviors",      "target": "datamodel",       "type": "flow"     },
    { "id": "e-datamodel-screens",     "source": "datamodel",      "target": "screens",         "type": "flow"     },
    { "id": "e-brand-screens",         "source": "brand-visual",   "target": "screens",         "type": "flow"     },
    { "id": "e-techstack-screens",     "source": "techstack",      "target": "screens",         "type": "flow"     },
    { "id": "e-screens-components",    "source": "screens",        "target": "components",      "type": "flow"     },
    { "id": "e-screens-mock",          "source": "screens",        "target": "mock",            "type": "optional" },
    { "id": "e-screens-storybook",     "source": "screens",        "target": "storybook",       "type": "flow"     },
    { "id": "e-techstack-storybook",   "source": "techstack",      "target": "storybook",       "type": "flow"     },
    { "id": "e-brand-storybook",       "source": "brand-visual",   "target": "storybook",       "type": "flow"     },
    { "id": "e-screens-ready",         "source": "screens",        "target": "ready",           "type": "flow"     },
    { "id": "e-ready-scaffold",        "source": "ready",          "target": "scaffold",        "type": "flow"     },
    { "id": "e-scaffold-foundation",   "source": "scaffold",       "target": "foundation",      "type": "flow"     },
    { "id": "e-foundation-design",     "source": "foundation",     "target": "design",          "type": "optional" },
    { "id": "e-foundation-migrate",    "source": "foundation",     "target": "migrate",         "type": "flow"     },
    { "id": "e-foundation-feature",    "source": "foundation",     "target": "feature",         "type": "flow"     },
    { "id": "e-design-feature",        "source": "design",         "target": "feature",         "type": "optional" },
    { "id": "e-migrate-seed",          "source": "migrate",        "target": "seed",            "type": "flow"     },
    { "id": "e-feature-test-plan",     "source": "feature",        "target": "test-plan",       "type": "flow"     },
    { "id": "e-test-plan-unit",        "source": "test-plan",      "target": "test-unit",       "type": "flow"     },
    { "id": "e-feature-integration",   "source": "feature",        "target": "test-integration","type": "flow"     },
    { "id": "e-feature-e2e",           "source": "feature",        "target": "e2e",             "type": "flow"     },
    { "id": "e-unit-verify",           "source": "test-unit",      "target": "verify",          "type": "flow"     },
    { "id": "e-integration-verify",    "source": "test-integration","target": "verify",         "type": "flow"     },
    { "id": "e-e2e-verify",            "source": "e2e",            "target": "verify",          "type": "flow"     }
  ],
  "entry": "overview"
}
