-- allium: 2
-- Behavioral spec for feature group: 02_tasks
-- Source: _concept/03_features/02_tasks/

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity User { email: Email, status: active | locked | unverified }
external entity Team { members: Set<User> }

------------------------------------------------------------
-- Entities
------------------------------------------------------------

entity Task {
    title: String
    description: String
    status: todo | in_progress | done
    priority: low | medium | high | urgent
    due_date: Date
    created_at: Timestamp

    -- Relationships
    creator: User
    assigned_to: User
    team: Team

    -- Derived
    is_overdue: due_date < now and status != done
    is_unassigned: assigned_to = null
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    default_priority: String = "medium"
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

rule CreateTask {
    when: CreateTask(creator, team, title, description, assignee, priority, due_date)
    requires: creator in team.members
    requires: title != ""
    ensures: Task.created(
        title: title,
        description: description ?? "",
        status: todo,
        priority: priority ?? config.default_priority,
        due_date: due_date,
        creator: creator,
        assigned_to: assignee,
        team: team,
        created_at: now
    )
}

rule CreateTaskInvalidTitle {
    when: CreateTask(_, _, title, _, _, _, _)
    requires: title = ""
    ensures: ValidationError("Title is required")
}

rule AssignTask {
    when: AssignTask(task, assignee)
    requires: task.status != done
    requires: assignee in task.team.members
    ensures: task.assigned_to = assignee
}

rule AssignTaskInvalidMember {
    when: AssignTask(task, assignee)
    requires: assignee not in task.team.members
    ensures: ValidationWarning("Assignee is not a team member, falling back to unassigned")
    ensures: task.assigned_to = null
}

rule MoveTaskToInProgress {
    when: task: Task.status transitions_to in_progress
    requires: task.status = todo
    ensures: task.status = in_progress
}

rule CompleteTask {
    when: CompleteTask(task)
    requires: task.status in {todo, in_progress}
    ensures: task.status = done
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface TaskBoard {
    facing viewer: User

    context team: Team where members includes viewer

    exposes:
        for task in team.tasks:
            task.title
            task.status
            task.priority
            task.assigned_to
            task.due_date
            task.is_overdue

    provides:
        CreateTask(viewer, team, title, description, assignee, priority, due_date)
        AssignTask(task, assignee)
            when task.status != done
        CompleteTask(task)
            when task.status != done
}

surface QuickAdd {
    facing viewer: User

    context team: Team where members includes viewer

    provides:
        CreateTask(viewer, team, title, "", null, null, null)
}
