-- allium: 2
-- Behavioral spec for feature group: 01_user_auth
-- Source: _concept/03_features/01_user_auth/

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity EmailService { send: (to: Email, subject: String, body: String) }

------------------------------------------------------------
-- Entities
------------------------------------------------------------

entity User {
    email: Email
    password_hash: String
    status: active | locked | unverified
    failed_login_count: Integer
    last_login_at: Timestamp

    -- Relationships
    sessions: Session with user = this

    -- Derived
    is_locked: status = locked
}

entity Session {
    user: User with sessions = this
    token: String
    remember_me: Boolean
    expires_at: Timestamp
    status: active | expired

    -- Derived
    is_expired: expires_at <= now and status = active
}

entity VerificationToken {
    user: User
    token: String
    expires_at: Timestamp
    status: pending | used | expired
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    max_login_attempts: Integer = 5
    session_timeout: Duration = 24.hours
    remember_me_timeout: Duration = 30.days
    verification_expiry: Duration = 24.hours
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

rule UserRegisters {
    when: RegisterUser(email, password)
    requires: not User.any(u => u.email = email)
    ensures: User.created(email: email, password_hash: password, status: unverified, failed_login_count: 0)
    ensures: VerificationToken.created(user: user, status: pending, expires_at: now + config.verification_expiry)
    ensures: SendVerificationEmail(user)
}

rule SendVerificationEmail {
    when: SendVerificationEmail(user)
    requires: user.status = unverified
    ensures: EmailService.send(to: user.email, subject: "Verify your email", body: "...")
}

rule UserVerifiesEmail {
    when: VerifyEmail(token)
    requires: token.status = pending
    requires: token.expires_at > now
    ensures: token.status = used
    ensures: token.user.status = active
}

rule VerificationTokenExpires {
    when: token: VerificationToken.expires_at <= now
    requires: token.status = pending
    ensures: token.status = expired
}

rule UserLogin {
    when: LoginAttempt(user, credentials, remember)
    requires: user.status = active
    requires: credentials.valid
    ensures: Session.created(user: user, remember_me: remember, status: active, expires_at: now + if remember: config.remember_me_timeout else: config.session_timeout)
    ensures: user.last_login_at = now
    ensures: user.failed_login_count = 0
}

rule LoginFailure {
    when: LoginAttempt(user, credentials, _)
    requires: user.status = active
    requires: not credentials.valid
    ensures: user.failed_login_count = user.failed_login_count + 1
}

rule AccountLockout {
    when: user: User.failed_login_count >= config.max_login_attempts
    requires: user.status = active
    ensures: user.status = locked
}

rule SessionExpires {
    when: session: Session.expires_at <= now
    requires: session.status = active
    ensures: session.status = expired
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface LoginPage {
    facing visitor: User

    exposes:
        -- no data exposed (unauthenticated)

    provides:
        LoginAttempt(visitor, credentials, remember)
            when visitor.status = active
}

surface RegistrationPage {
    facing visitor: User

    exposes:
        -- no data exposed (unauthenticated)

    provides:
        RegisterUser(email, password)
}

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open question "Should locked accounts auto-unlock after a timeout, or require admin intervention?"
open question "Should we support social login or magic link as alternatives to password?"
