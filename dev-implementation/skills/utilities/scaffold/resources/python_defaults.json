{
  "pyproject.toml": {
    "tool.ruff": {
      "line-length": 100,
      "target-version": "py312",
      "lint.select": [
        "E",
        "F",
        "I",
        "W",
        "UP",
        "B",
        "SIM"
      ]
    },
    "tool.pytest.ini_options": {
      "addopts": "--cov --strict-markers",
      "testpaths": [
        "tests"
      ]
    }
  },
  "structure": [
    "src",
    "tests",
    "docs",
    "scripts",
    "knowledge"
  ]
}