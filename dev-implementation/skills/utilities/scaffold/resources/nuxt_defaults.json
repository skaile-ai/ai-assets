{
  "nuxt.config.ts": {
    "modules": [
      "@nuxt/ui",
      "@vueuse/nuxt"
    ],
    "future": {
      "compatibilityVersion": 4
    },
    "devtools": {
      "enabled": true
    },
    "typescript": {
      "strict": true,
      "typeCheck": true
    }
  },
  "structure": [
    "app/components",
    "app/pages",
    "app/layouts",
    "app/assets/css",
    "app/composables",
    "app/utils",
    "server/api",
    "knowledge"
  ]
}